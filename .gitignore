# VerordnungsAmpel — .gitignore

# Referenz-Codebases (NICHT mit veroeffentlichen, urheberrechtlich geschuetzt)
_codebases/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Tests / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/
.cache/
.tox/
.nox/
.hypothesis/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Compliance-Log und User-DB (NIE committen)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm
compliance_log/
~/.verordnungsampel/

# Lokale User-Dateien
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
.env
.env.*
*.local
*.secret
*.secrets
*.p12
*.pfx
*.pem
*.key
secrets.*
secret.*
credentials.*
credential.*
client_secret*.json
token.*

# Interne Steuerungsdateien (Um:bruch / .SOFTWARE-Konvention)
AUFGABEN.txt
BUGREPORT.md
DIAGNOSE_REPORT.md
SKILL.md
tmpclaude-*

# Rechtsdokumente als lokale Entwürfe (nur das finale PDF/MD kommt ins Repo via docs/legal/)
docs/legal/*_DRAFT.md
docs/legal/*.docx

# Lokale Release-Artefakte (GitHub Releases sind primärer Kanal)
releases/
*.exe
*.msi
*.msix
*.appx
*.zip
*.7z
*.spec
*.log

# RB-Review 2026-04-13: interne Audit- und Cross-Projekt-Dokumente - nicht public
docs/internal/
docs/legal/RECHTSAUDIT_ALLE_PROJEKTE.md
docs/legal/AUTOFIX_REPORT.md
docs/legal/LICENSE_SWEEP_REPORT.md
docs/legal/GUTACHTEN_VFDistiller_IVDR.md
docs/legal/GUTACHTEN_VFDistiller_IVDR_NACHTRAG.md
docs/legal/GESAMTEINSCHAETZUNG_FULL.md

docs/CODE_AUDIT.md
